    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400;1,600&family=JetBrains+Mono:ital,wght@0,300;0,500;1,400&family=Outfit:wght@300;400;500;600;800&display=swap"
        rel="stylesheet">
    <!-- GSAP core and ScrollTrigger -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <style>
        body {
            background-color: #F8F5F2;
            color: #1E1E1E;
            overflow-x: hidden;
            /* SVG Noise Overlay */
            background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)" opacity="0.05"/%3E%3C/svg%3E');
        }

        .cormorant-italic {
            font-family: 'Cormorant Garamond', serif;
            font-style: italic;
        }

        /* Glassmorphism nav */
        .nav-glass {
            background: rgba(248, 245, 242, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(30, 30, 30, 0.05);
        }

        /* Magnetic button logic handled partially in React, styles here */
        .btn-magnetic {
            position: relative;
            overflow: hidden;
            border-radius: 9999px;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            z-index: 1;
        }

        .btn-magnetic::before {
            content: '';
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            height: 100%;
            background: #1E1E1E;
            /* Hover override color */
            transition: transform 0.4s cubic-bezier(0.7, 0, 0.2, 1);
            z-index: -1;
            border-radius: 50% 50% 0 0;
        }

        .btn-magnetic:hover::before {
            transform: translateY(-100%);
            border-radius: 0;
        }

        .btn-magnetic:hover {
            color: #F8F5F2 !important;
        }

        /* Acordeon Fotográfico */
        .accordion-item {
            transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .accordion-item>.image-cover {
            transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .accordion-item:hover {
            flex-grow: 1.5;
        }

        .accordion-item:hover>.image-cover {
            transform: scale(1.05);
        }

        /* Ocultar barra de scroll para estetica */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #F8F5F2;
        }

        ::-webkit-scrollbar-thumb {
            background: #C24127;
            border-radius: 4px;
        }

        .floating-plate {
            filter: drop-shadow(0 30px 40px rgba(0, 0, 0, 0.15));
        }

        .clip-text-reveal {
            clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
        }
    </style>
</head>

<body class="antialiased selection:bg-capo-accent selection:text-white">
    <div id="root"></div>

    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://unpkg.com/feather-icons"></script>

    <script type="text/babel">
        const { useState, useEffect, useRef, useLayoutEffect } = React;
        gsap.registerPlugin(ScrollTrigger);

        const App = () => {
            const appRef = useRef(null);

            useLayoutEffect(() => {
                let ctx = gsap.context(() => {

                    // Navbar morphing
                    ScrollTrigger.create({
                        start: "top -50",
                        end: 99999,
                        toggleClass: { className: "nav-glass", targets: ".navbar" },
                    });

                    // Hero animations
                    const tl = gsap.timeline();
                    tl.from(".hero-title .word", {
                        y: 100,
                        opacity: 0,
                        duration: 1.2,
                        stagger: 0.15,
                        ease: "power4.out",
                        delay: 0.2
                    })
                        .from(".hero-product", {
                            scale: 0.8,
                            opacity: 0,
                            rotation: -15,
                            duration: 1.5,
                            ease: "elastic.out(1, 0.5)"
                        }, "-=1")
                        .from(".hero-metrics", {
                            y: 20,
                            opacity: 0,
                            stagger: 0.1,
                            ease: "power2.out"
                        }, "-=1");

                    // Flotación constante del producto en el Hero
                    gsap.to(".hero-product", {
                        y: -20,
                        rotation: 3,
                        duration: 4,
                        repeat: -1,
                        yoyo: true,
                        ease: "sine.inOut"
                    });

                    // Baraja Diagnóstica
                    gsap.from(".card-baraja", {
                        scrollTrigger: {
                            trigger: ".section-baraja",
                            start: "top 70%",
                        },
                        y: 100,
                        opacity: 0,
                        rotation: index => [-5, 0, 5][index],
                        stagger: 0.2,
                        duration: 1,
                        ease: "power3.out"
                    });

                    // Manifiesto Parallax Split Text (Simulado con spans)
                    const manifestoWords = gsap.utils.toArray('.manifesto-word');
                    gsap.from(manifestoWords, {
                        scrollTrigger: {
                            trigger: ".section-manifesto",
                            start: "top 60%",
                        },
                        y: 50,
                        opacity: 0,
                        stagger: 0.05,
                        duration: 0.8,
                        ease: "back.out(1.7)"
                    });

                    // Tarjetas Apilables (Scroll Stacking logic)
                    const panels = gsap.utils.toArray('.stack-panel');
                    panels.forEach((panel, i) => {
                        ScrollTrigger.create({
                            trigger: panel,
                            start: "top top",
                            pin: true,
                            pinSpacing: false
                        });

                        // Si hay un panel delante, el actual se achica y difumina
                        if (i !== panels.length - 1) {
                            gsap.to(panel, {
                                scale: 0.85,
                                opacity: 0.3,
                                filter: "blur(15px)",
                                scrollTrigger: {
                                    trigger: panels[i + 1],
                                    start: "top bottom",
                                    end: "top top",
                                    scrub: true,
                                }
                            });
                        }
                    });

                }, appRef);

                feather.replace();
                return () => ctx.revert();
            }, []);

            return (
                <div ref={appRef} className="font-sans text-capo-text">

                    {/* Isla Flotante Navbar */}

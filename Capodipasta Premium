                                        <div className="w-8 h-8 rounded-full bg-capo-accent/20 flex items-center justify-center">
                                            <i data-feather="clock" className="w-4 h-4 text-capo-accent"></i>
                                        </div>
                                        <div>
                                            <p className="text-[10px] uppercase font-bold text-capo-text/50 tracking-wider">Cocción</p>
                                            <p className="font-mono font-bold text-capo-text">3 - 4 Min</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    {/* BARAJA DIAGNÓSTICA (Propuesta de valor) */}
                    <section id="artesanal" className="section-baraja py-32 px-6 bg-white overflow-hidden">
